# Mailtrap
MAILTRAP_API_TOKEN=
MAILTRAP_USE_SANDBOX=true
MAILTRAP_INBOX_ID=

# Four templates: team + client for booking and enquiry
MAILTRAP_TEMPLATE_BOOKING_TEAM_UUID=
MAILTRAP_TEMPLATE_BOOKING_CLIENT_UUID=
MAILTRAP_TEMPLATE_ENQUIRY_TEAM_UUID=
MAILTRAP_TEMPLATE_ENQUIRY_CLIENT_UUID=

MAIL_FROM_EMAIL=sandbox@mailtrap.io
MAIL_FROM_NAME=Beyond Accra Concierge

TEAM_EMAILS=travel@beyondaccra.com,ama@snowwhitegroup.com,carl@beyondaccra.com,operations@beyondaccra.com

# Cloudflare Turnstile (bot protection)
# Create at: Cloudflare Dashboard → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
